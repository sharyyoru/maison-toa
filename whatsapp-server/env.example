# Server Configuration
PORT=3001
WA_SERVER_PORT=3001

# CORS - Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://aestheticclinic.vercel.app

# Authentication - JWT secret (should match your main app's JWT secret)
JWT_SECRET=your-jwt-secret-here
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# Persistent storage paths (mount Railway volume at /data)
DB_PATH=/data/sessions.db
WA_SESSION_PATH=/data/whatsapp-sessions

# Supabase - For queue processor to poll whatsapp_queue table
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Queue Processor - Polling interval in milliseconds (default 10000 = 10s)
QUEUE_POLL_INTERVAL=10000

# Puppeteer - Path to Chromium executable (set automatically in Docker)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
